Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block access to sensitive files at the public/ level
<FilesMatch "\.(sh|sql|log|env|bak|md)$">
    Require all denied
</FilesMatch>

# CI3 URL rewriting — remove index.php from URLs
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block access to application/ and system/ if somehow reachable
    RewriteRule ^(application|system|storage|logs)/ - [F,L]

    # Allow existing files and directories to pass through
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else through index.php
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    # Without mod_rewrite, add index.php to all URLs
    ErrorDocument 404 /index.php
</IfModule>
